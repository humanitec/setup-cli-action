{
  "name": "setup-cli-action",
  "version": "0.0.0",
  "author": "",
  "private": true,
  "description": "GitHub Action to set up the Humanitec CLI",
  "homepage": "https://github.com/humanitec/setup-cli-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/humanitec/setup-cli-action.git"
  },
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/humanitec/setup-cli-action/issues"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:write": "prettier --write **/*.ts",
    "format:check": "prettier --check **/*.ts",
    "lint": "npx eslint",
    "package": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest",
      "node_modules/@actions/.+\\.js$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!@actions/)"
    ],
    "resolver": "./__tests__/jest-resolver.js"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/tool-cache": "^4.0.0",
    "@octokit/rest": "^20.1.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.57.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsonc": "^2.21.1",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "minimatch@3": "3.1.5",
    "minimatch@9": "9.0.9"
  }
}
